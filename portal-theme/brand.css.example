/* tyk-launchpad brand overlay — appended AFTER the theme's main.css so these win.
 * Override only the official CSS custom properties documented in
 * vendor/tyk-docs/portal/customization/branding.mdx. Replace the placeholder
 * values below with the customer's brand. Nothing here duplicates Tyk theme code —
 * it is a thin override layer. */
:root {
  /* Backgrounds */
  --tdp-nav-bg-color: #0a1f2e;      /* navigation bar */
  --tdp-body-bg-color: #ffffff;     /* app background */

  /* Text + links */
  --tdp-text-color: #1a1a1a;
  --tdp-link-color: #0a7d8c;
  --tdp-nav-link-color: #ffffff;

  /* Primary button */
  --tdp-primary-btn-color: #0a7d8c;
  --tdp-primary-btn-border: #0a7d8c;

  /* Secondary button */
  --tdp-secondary-btn-color: #ffffff;
  --tdp-secondary-btn-border: #0a7d8c;

  /* Tables */
  --tdp-table-border-color: #e2e8f0;
}
